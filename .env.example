# ─── APP ────────────────────────────────────────────────
APP_NAME=FitForge
APP_ENV=development
APP_URL=http://localhost

# ─── DATABASE ───────────────────────────────────────────
POSTGRES_DB=fitforge
POSTGRES_USER=fitforge
POSTGRES_PASSWORD=fitforge_secret
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# ─── REDIS ──────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=redis_secret

# ─── AUTH SERVICE (Java) ────────────────────────────────
AUTH_SERVICE_PORT=8081
JWT_SECRET=your_super_secret_jwt_key_change_in_production_min_256_bits
JWT_EXPIRATION=86400000
JWT_REFRESH_EXPIRATION=604800000
TOTP_ISSUER=FitForge

# ─── API SERVICE (Node.js) ──────────────────────────────
API_SERVICE_PORT=3001
API_SERVICE_URL=http://api-service:3001

# ─── DIET SERVICE (Laravel) ─────────────────────────────
DIET_SERVICE_PORT=8082
DIET_APP_KEY=base64:your_laravel_app_key_here

# ─── AI SERVICE (Python) ────────────────────────────────
AI_SERVICE_PORT=8000
AI_SERVICE_URL=http://ai-service:8000

# ─── FRONTEND ───────────────────────────────────────────
FRONTEND_PORT=5173
VITE_API_URL=http://localhost/api
VITE_AUTH_URL=http://localhost/auth
VITE_DIET_URL=http://localhost/diet
VITE_AI_URL=http://localhost/ai
VITE_WS_URL=ws://localhost/ws

# ─── MAIL ───────────────────────────────────────────────
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM=noreply@fitforge.app

# ─── EXTERNAL APIs ──────────────────────────────────────
OPEN_FOOD_FACTS_API=https://world.openfoodfacts.org/api/v2
FIREBASE_SERVER_KEY=

# ─── STORAGE ────────────────────────────────────────────
STORAGE_DRIVER=local
AWS_BUCKET=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=eu-west-1
