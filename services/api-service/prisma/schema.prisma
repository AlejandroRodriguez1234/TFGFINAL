generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// HABITS
model Habit {
  id             String      @id @default(uuid())
  userId         String      @map("user_id")
  name           String
  description    String?
  icon           String      @default("star")
  color          String      @default("from-brand-500 to-cyan-400")
  frequency      HabitFreq   @default(DAILY)
  targetDays     Int[]       @map("target_days")
  streak         Int         @default(0)
  longestStreak  Int         @default(0) @map("longest_streak")
  completionRate Float       @default(0) @map("completion_rate")
  isActive       Boolean     @default(true) @map("is_active")
  createdAt      DateTime    @default(now()) @map("created_at")
  updatedAt      DateTime    @updatedAt @map("updated_at")
  logs           HabitLog[]

  @@map("habits")
}

model HabitLog {
  id          String   @id @default(uuid())
  habitId     String   @map("habit_id")
  habit       Habit    @relation(fields: [habitId], references: [id], onDelete: Cascade)
  completedAt DateTime @default(now()) @map("completed_at")
  notes       String?

  @@map("habit_logs")
}

enum HabitFreq {
  DAILY
  WEEKLY
  CUSTOM
}

// GYM
model Exercise {
  id              String        @id @default(uuid())
  name            String
  description     String        @db.Text
  muscleGroups    MuscleGroup[] @map("muscle_groups")
  primaryMuscle   MuscleGroup   @map("primary_muscle")
  difficulty      Difficulty
  equipment       Equipment[]
  gifUrl          String?       @map("gif_url")
  videoUrl        String?       @map("video_url")
  instructions    String[]
  tips            String[]
  isCustom        Boolean       @default(false) @map("is_custom")
  createdByUserId String?       @map("created_by_user_id")
  createdAt       DateTime      @default(now()) @map("created_at")

  @@map("exercises")
}

model WorkoutTemplate {
  id               String            @id @default(uuid())
  userId           String?           @map("user_id")
  name             String
  description      String?
  difficulty       Difficulty
  estimatedMinutes Int               @map("estimated_minutes")
  muscleGroups     MuscleGroup[]     @map("muscle_groups")
  isPublic         Boolean           @default(false) @map("is_public")
  exercises        WorkoutExercise[]
  logs             WorkoutLog[]
  routineDays      RoutineDay[]
  createdAt        DateTime          @default(now()) @map("created_at")
  updatedAt        DateTime          @updatedAt @map("updated_at")

  @@map("workout_templates")
}

model WorkoutExercise {
  id         String          @id @default(uuid())
  templateId String          @map("template_id")
  template   WorkoutTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  exerciseId String          @map("exercise_id")
  order      Int
  sets       Json
  notes      String?

  @@map("workout_exercises")
}

model WorkoutLog {
  id          String           @id @default(uuid())
  userId      String           @map("user_id")
  templateId  String?          @map("template_id")
  template    WorkoutTemplate? @relation(fields: [templateId], references: [id])
  name        String
  startedAt   DateTime         @map("started_at")
  finishedAt  DateTime?        @map("finished_at")
  durationMin Int?             @map("duration_min")
  totalVolume Float?           @map("total_volume")
  exercises   Json
  notes       String?
  xpEarned    Int              @default(0) @map("xp_earned")
  createdAt   DateTime         @default(now()) @map("created_at")

  @@map("workout_logs")
}

model Routine {
  id        String       @id @default(uuid())
  userId    String       @map("user_id")
  name      String
  isActive  Boolean      @default(false) @map("is_active")
  days      RoutineDay[]
  createdAt DateTime     @default(now()) @map("created_at")
  updatedAt DateTime     @updatedAt @map("updated_at")

  @@map("routines")
}

model RoutineDay {
  id         String          @id @default(uuid())
  routineId  String          @map("routine_id")
  routine    Routine         @relation(fields: [routineId], references: [id], onDelete: Cascade)
  dayOfWeek  Int             @map("day_of_week")
  templateId String          @map("template_id")
  template   WorkoutTemplate @relation(fields: [templateId], references: [id])

  @@map("routine_days")
}

enum MuscleGroup {
  CHEST
  BACK
  SHOULDERS
  ARMS
  CORE
  LEGS
  GLUTES
  CARDIO
}

enum Difficulty {
  BEGINNER
  INTERMEDIATE
  ADVANCED
}

enum Equipment {
  BARBELL
  DUMBBELL
  MACHINE
  BODYWEIGHT
  CABLE
  KETTLEBELL
  BANDS
}

// BODY MEASUREMENTS
model BodyMeasurement {
  id         String   @id @default(uuid())
  userId     String   @map("user_id")
  date       DateTime @default(now())
  weight     Float
  height     Float?
  bodyFat    Float?   @map("body_fat")
  muscleMass Float?   @map("muscle_mass")
  waist      Float?
  chest      Float?
  hips       Float?
  arms       Float?
  thighs     Float?
  bmi        Float?
  hydration  Float?
  notes      String?
  createdAt  DateTime @default(now()) @map("created_at")

  @@map("body_measurements")
}

// GAMIFICATION
model Achievement {
  id          String              @id @default(uuid())
  key         String              @unique
  name        String
  description String
  icon        String
  xpReward    Int                 @map("xp_reward")
  category    AchievementCategory
  users       UserAchievement[]
  createdAt   DateTime            @default(now()) @map("created_at")

  @@map("achievements")
}

model UserAchievement {
  id            String      @id @default(uuid())
  userId        String      @map("user_id")
  achievementId String      @map("achievement_id")
  achievement   Achievement @relation(fields: [achievementId], references: [id])
  unlockedAt    DateTime    @default(now()) @map("unlocked_at")

  @@unique([userId, achievementId])
  @@map("user_achievements")
}

enum AchievementCategory {
  FITNESS
  NUTRITION
  STREAK
  SOCIAL
  MILESTONE
}

// SOCIAL
model Friendship {
  id          String           @id @default(uuid())
  requesterId String           @map("requester_id")
  addresseeId String           @map("addressee_id")
  status      FriendshipStatus @default(PENDING)
  createdAt   DateTime         @default(now()) @map("created_at")
  updatedAt   DateTime         @updatedAt @map("updated_at")

  @@unique([requesterId, addresseeId])
  @@map("friendships")
}

model Post {
  id            String        @id @default(uuid())
  userId        String        @map("user_id")
  content       String        @db.Text
  imageUrl      String?       @map("image_url")
  workoutLogId  String?       @map("workout_log_id")
  likes         Int           @default(0)
  commentsCount Int           @default(0) @map("comments_count")
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")
  comments      PostComment[]

  @@map("posts")
}

model PostComment {
  id        String   @id @default(uuid())
  postId    String   @map("post_id")
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  userId    String   @map("user_id")
  username  String
  content   String   @db.Text
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("post_comments")
}

model Challenge {
  id           String          @id @default(uuid())
  creatorId    String          @map("creator_id")
  name         String
  description  String?
  type         ChallengeType
  target       Float
  startDate    DateTime        @map("start_date")
  endDate      DateTime        @map("end_date")
  status       ChallengeStatus @default(PENDING)
  participants Json
  createdAt    DateTime        @default(now()) @map("created_at")

  @@map("challenges")
}

enum FriendshipStatus {
  PENDING
  ACCEPTED
  REJECTED
  BLOCKED
}

enum ChallengeType {
  STEPS
  WORKOUTS
  CALORIES
  STREAK
  WEIGHT
}

enum ChallengeStatus {
  PENDING
  ACTIVE
  COMPLETED
  CANCELLED
}

// NOTIFICATIONS
model Notification {
  id        String           @id @default(uuid())
  userId    String           @map("user_id")
  type      NotificationType
  title     String
  message   String
  isRead    Boolean          @default(false) @map("is_read")
  actionUrl String?          @map("action_url")
  createdAt DateTime         @default(now()) @map("created_at")

  @@index([userId, isRead])
  @@map("notifications")
}

enum NotificationType {
  WORKOUT
  DIET
  ACHIEVEMENT
  SOCIAL
  SYSTEM
}
